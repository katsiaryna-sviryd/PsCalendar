{
  "name": "PsCalendar",
  "description": "Detects upcoming events text on the current page.",
  "version": "0.1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "512": "icons/icon512.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "512": "icons/icon512.png"
  },
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["https://practiscore.com/*"],
  "background": {
    "service_worker": "background.js"
  }
}
